*
!/.gitignore
!/.dockerignore

################################################################
# MAIN FOLDER
################################################################

!/.env
!/README.md
!/ISSUES.md
!/LICENSE

!/scripts
!/scripts/*.sh
!/scripts/REQUIREMENTS_*

################################################################
# WHALES
################################################################

!/.whales
!/.whales.env
!/.whales.Dockerfile
!/.whales.docker-compose.yml

################################################################
# PROJECT FILES
################################################################

!/src
!/src/**

!/test

!/data
/data/**
!/data/*-example.*

!/dist
!/dist/VERSION

################################################################
# AUXLIARY
################################################################

/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.DS_Store
/**/__archive__*

################################################################
# Git Keep
################################################################

!/**/.gitkeep
