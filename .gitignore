*
!/.gitignore
!/.dockerignore

################################################################
# MAIN FOLDER
################################################################

!/.env
!/README.md
!/ISSUES.md
!/LICENSE

!/scripts
!/scripts/*.sh
!/scripts/REQUIREMENTS_*

################################################################
# WHALES
################################################################

!/.whales
!/.whales.env
!/.whales.Dockerfile
!/.whales.docker-compose.yml

################################################################
# PROJECT FILES
################################################################

!/src
!/src/**

!/test
!/test/cases
!/test/cases/case*
!/test/cases/case*/**/
!/test/cases/setup
!/test/unit
!/test/**/*.py
!/test/**/*.tex
!/test/**/*.yml

!/data
/data/**
!/data/*-example.*

!/dist
!/dist/VERSION

################################################################
# AUXLIARY
################################################################

/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.DS_Store
/**/__archive__*
/**/sandbox

################################################################
# Git Keep
################################################################

!/**/.gitkeep
