*
!/.gitignore

################################################################
# GITHUB
################################################################

!/.github
!/.github/workflows
!/.github/**/*.yml

################################################################
# MAIN FOLDER
################################################################

!/.env
!/README.md
!/LONGREADME.md
!/ISSUES.md
!/LICENSE

!/scripts
!/scripts/*.sh
!/scripts/REQUIREMENTS_*

!/install
!/install/installphpytex
!/install/README.md

################################################################
# PROJECT FILES
################################################################

!/python
!/python/src
!/python/src/**/
!/python/src/setup/templates/template_*
!/python/src/setup/VERSION
!/python/src/**/*.lark
!/python/src/**/*.py
!/python/test
!/python/test/**
!/python/test/unit/**
!/python/test/**/*.py

!/golang
!/golang/**/
!/golang/**/*.go
!/golang/src/go.mod
!/golang/src/go.sum

!/test
!/test/setup
!/test/setup/config.yml
!/test/cases
!/test/cases/case_*
!/test/cases/case_*/**/
!/test/cases/**/*.yml
!/test/cases/**/*.tex

!/examples

!/dist
!/dist/VERSION

################################################################
# AUXLIARY
################################################################

/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.DS_Store
/**/__archive__*
/**/sandbox

################################################################
# Git Keep
################################################################

!/**/.gitkeep
