*

## files at root level:
!.gitignore
!README.md
# needed for project
!.lib.sh
!build.sh
!test.sh
!clean.sh
!compile
!localpython
# setup files for programme
!setup.yml
# needed for pyinstaller
!LICENSE
!MANIFEST.in
!setup.py

## project structure
# SRC:
!src
!src/**
src/setup/**
!src/setup/*.yml
src/**/__pycache__
src/*.spec
# TEST:
!test
!test/main.py
!test/setup
test/setup/**
!test/setup/*.yml
test/**/__pycache__
!test/logs
test/logs/**/*
# DIST:
!dist
dist/*
dist/**/*
!dist/VERSION
!dist/RELEASENOTES
!dist/phpytex

# ## for build jobs
# !.github
# !.github/workflows
# !.github/workflows/**/*

## allow preservation of non-empty folders:
!**/.gitkeep
