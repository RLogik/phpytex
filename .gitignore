*
!/.gitignore

################################################################
# MAIN FOLDER
################################################################

!/README.md
!/LONGREADME.md
!/LICENSE
!/justfile
!/requirements*
!/.coveragerc
!/pyproject.toml

################################################################
# PROJECT FILES
################################################################

!/src
!/src/**/
!/src/setup/templates/template_*
!/src/setup/VERSION
!/src/**/*.py

!/tests
!/tests/**/
!/tests/cases/case_*/**
!/tests/**/*.py
!/tests/**/*.tex
!/tests/**/*.yaml

!/examples

!/models
!/models/*-schema.yaml
!/models/README.md

!/documentation
!/documentation/*/
!/documentation/*/Models/
!/documentation/**/*.md

!/tests
!/tests/**/
!/tests/**/*.py

!/assets
!/assets/*.lark
!/assets/template_*

!/dist
!/dist/VERSION

!/install
!/install/installphpytex
!/install/README.md

################################################################
# AUXLIARY
################################################################

/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.pytest_cache
/**/.DS_Store
/**/__archive__*
/**/sandbox

################################################################
# Git Keep
################################################################

!/**/.gitkeep
