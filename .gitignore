*

## files at root level:
!.gitignore
!README.md
# needed for project
!.lib.sh
!build.sh
!test.sh
!clean.sh
!compile
!localpython
# setup files for programme
!setup.yml
# needed for pyinstaller
!LICENSE
!MANIFEST.in
!setup.py

## project structure
# SRC:
!src
!src/**
src/**/__pycache__
!src/logs
src/*.spec
src/logs/**/*
# TEST:
!test
!test/**
test/**/__pycache__
!test/logs
test/logs/**/*
# DIST:
!dist
dist/**/*
!dist/VERSION
!dist/RELEASENOTES

## for build jobs
!.github
!.github/workflows
!.github/workflows/**/*

## allow preservation of non-empty folders:
!**/.gitkeep
