*
!/.gitignore

################################################################
# MAIN FOLDER
################################################################

!/README.md
!/LONGREADME.md
!/LICENSE
!/justfile
!/requirements*
!/.coveragerc
!/pyproject.toml

################################################################
# PROJECT FILES
################################################################

!/src
!/src/**/
!/src/setup/templates/template_*
!/src/setup/VERSION
!/src/**/*.py
!/src/config.yaml

!/examples

!/models*
!/models*/*-schema.yaml
!/models*/README.md

!/documentation
!/documentation/**/
!/documentation/**/*.md

!/tests
!/tests/**/
!/tests/**/*.py
!/tests/config.yaml
/tests/cases/**
!/tests/cases/case_*/
!/tests/cases/case_*/**/*.py
!/tests/cases/case_*/**/*.tex
!/tests/cases/case_*/**/*.yaml

!/assets
!/assets/*.lark
!/assets/template_*

!/dist
!/dist/VERSION

!/install
!/install/installphpytex
!/install/README.md

################################################################
# AUXLIARY
################################################################

/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.pytest_cache
/**/.DS_Store
/**/__archive__*
/**/sandbox

################################################################
# Git Keep
################################################################

!/**/.gitkeep
