*

################################################################
# MAIN FOLDER
################################################################

!/.env
!/README.md
!/ISSUES.md
!/LICENSE

!/scripts
!/scripts/*.sh
!/scripts/REQUIREMENTS_*

################################################################
# WHALES
################################################################

!/.whales
!/.whales.env

################################################################
# PROJECT FILES
################################################################

!/src
!/src/**

!/test
!/test/**

################################################################
# EXCLUDED FOLDERS (e.g. for mount-only volumes)
################################################################

/dist
/data
/build
/logs

################################################################
# ARTEFACTS
################################################################

/**/__pycache__
/**/.DS_Store
/**/__archive__*

################################################################
# Git Keep
################################################################

!/**/.gitkeep
